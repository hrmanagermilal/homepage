{
  "openapi": "3.0.3",
  "info": {
    "title": "Milal Church Homepage API",
    "description": "밀알교회 홈페이지 REST API",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/api", "description": "Current server" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "status": { "type": "integer", "example": 200 },
          "data": {}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "status": { "type": "integer" },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "tags": [
    { "name": "Auth", "description": "인증" },
    { "name": "Hero", "description": "히어로 섹션" },
    { "name": "Hero Links", "description": "히어로 링크" },
    { "name": "Sermons", "description": "설교" },
    { "name": "Bulletins", "description": "주보" },
    { "name": "Announcements", "description": "공지사항" },
    { "name": "Together", "description": "함께해요" },
    { "name": "Departments", "description": "부서" },
    { "name": "NextGen", "description": "다음세대" },
    { "name": "Ministry", "description": "사역" },
    { "name": "News", "description": "소식" },
    { "name": "Members", "description": "교역자/직원" },
    { "name": "Users", "description": "관리자 계정" },
    { "name": "Landing Titles", "description": "랜딩페이지 타이틀" },
    { "name": "Analytics", "description": "페이지뷰 통계" },
    { "name": "Tracking", "description": "페이지뷰 트래킹" }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["Auth"],
        "summary": "API health check",
        "responses": {
          "200": { "description": "API is running", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string", "format": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그아웃",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logged out" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "현재 로그인 사용자 정보",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Current user info" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/hero": {
      "get": {
        "tags": ["Hero"],
        "summary": "히어로 섹션 데이터 조회",
        "responses": {
          "200": { "description": "Hero section data" }
        }
      }
    },
    "/hero-links": {
      "get": {
        "tags": ["Hero Links"],
        "summary": "히어로 링크 목록 조회",
        "responses": {
          "200": { "description": "List of hero links" }
        }
      },
      "post": {
        "tags": ["Hero Links"],
        "summary": "히어로 링크 생성",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },
    "/hero-links/{id}": {
      "get": {
        "tags": ["Hero Links"],
        "summary": "히어로 링크 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Hero link" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "tags": ["Hero Links"],
        "summary": "히어로 링크 수정",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Hero Links"],
        "summary": "히어로 링크 삭제",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/sermons": {
      "get": {
        "tags": ["Sermons"],
        "summary": "설교 목록 조회",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "List of sermons" }
        }
      }
    },
    "/sermons/{id}": {
      "get": {
        "tags": ["Sermons"],
        "summary": "설교 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Sermon" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/bulletins": {
      "get": {
        "tags": ["Bulletins"],
        "summary": "주보 목록 조회",
        "responses": {
          "200": { "description": "List of bulletins" }
        }
      }
    },
    "/bulletins/{id}": {
      "get": {
        "tags": ["Bulletins"],
        "summary": "주보 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Bulletin" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/announcements": {
      "get": {
        "tags": ["Announcements"],
        "summary": "공지사항 목록 조회",
        "responses": {
          "200": { "description": "List of announcements" }
        }
      }
    },
    "/announcements/{id}": {
      "get": {
        "tags": ["Announcements"],
        "summary": "공지사항 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Announcement" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/together": {
      "get": {
        "tags": ["Together"],
        "summary": "함께해요 목록 조회",
        "responses": {
          "200": { "description": "List of together items" }
        }
      }
    },
    "/together/{id}": {
      "get": {
        "tags": ["Together"],
        "summary": "함께해요 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Together item" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/departments": {
      "get": {
        "tags": ["Departments"],
        "summary": "부서 목록 조회",
        "responses": {
          "200": { "description": "List of departments" }
        }
      }
    },
    "/departments/{id}": {
      "get": {
        "tags": ["Departments"],
        "summary": "부서 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Department" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/nextgen": {
      "get": {
        "tags": ["NextGen"],
        "summary": "다음세대 부서 목록 조회",
        "responses": {
          "200": { "description": "NextGen departments" }
        }
      }
    },
    "/nextgen/{id}": {
      "get": {
        "tags": ["NextGen"],
        "summary": "다음세대 부서 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "NextGen department" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/ministry": {
      "get": {
        "tags": ["Ministry"],
        "summary": "사역 목록 조회",
        "responses": {
          "200": { "description": "Ministry list" }
        }
      }
    },
    "/ministry/{id}": {
      "get": {
        "tags": ["Ministry"],
        "summary": "사역 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Ministry item" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/news": {
      "get": {
        "tags": ["News"],
        "summary": "소식 목록 조회",
        "responses": {
          "200": { "description": "List of news" }
        }
      }
    },
    "/news/{id}": {
      "get": {
        "tags": ["News"],
        "summary": "소식 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "News item" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/members": {
      "get": {
        "tags": ["Members"],
        "summary": "교역자/직원 목록 조회",
        "responses": {
          "200": { "description": "List of members" }
        }
      },
      "post": {
        "tags": ["Members"],
        "summary": "교역자/직원 생성",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },
    "/members/{id}": {
      "get": {
        "tags": ["Members"],
        "summary": "교역자/직원 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Member" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "tags": ["Members"],
        "summary": "교역자/직원 수정",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Members"],
        "summary": "교역자/직원 삭제",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/members/{role}/role": {
      "get": {
        "tags": ["Members"],
        "summary": "역할별 교역자/직원 조회",
        "parameters": [{ "name": "role", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Members by role" }
        }
      }
    },
    "/members/{id}/picture": {
      "post": {
        "tags": ["Members"],
        "summary": "교역자/직원 사진 업로드",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "picture": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Picture uploaded" }
        }
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "관리자 계정 목록 조회",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "List of users" }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "관리자 계정 생성",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "관리자 계정 단일 조회",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "User" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "관리자 계정 수정",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "관리자 계정 삭제",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/users/{id}/password": {
      "put": {
        "tags": ["Users"],
        "summary": "비밀번호 변경",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["current_password", "new_password"],
                "properties": {
                  "current_password": { "type": "string", "format": "password" },
                  "new_password": { "type": "string", "format": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password updated" }
        }
      }
    },
    "/landing-titles": {
      "get": {
        "tags": ["Landing Titles"],
        "summary": "랜딩페이지 타이틀 목록 조회",
        "responses": {
          "200": { "description": "List of landing titles" }
        }
      },
      "post": {
        "tags": ["Landing Titles"],
        "summary": "랜딩페이지 타이틀 생성",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },
    "/landing-titles/{id}": {
      "get": {
        "tags": ["Landing Titles"],
        "summary": "랜딩페이지 타이틀 단일 조회",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Landing title" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "tags": ["Landing Titles"],
        "summary": "랜딩페이지 타이틀 수정",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Landing Titles"],
        "summary": "랜딩페이지 타이틀 삭제",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/track/pageview": {
      "post": {
        "tags": ["Tracking"],
        "summary": "페이지뷰 기록",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "page": { "type": "string" },
                  "referrer": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Tracked" }
        }
      }
    },
    "/analytics/pages": {
      "get": {
        "tags": ["Analytics"],
        "summary": "페이지별 통계",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Page stats" }
        }
      }
    },
    "/analytics/devices": {
      "get": {
        "tags": ["Analytics"],
        "summary": "기기별 통계",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Device stats" }
        }
      }
    },
    "/analytics/browsers": {
      "get": {
        "tags": ["Analytics"],
        "summary": "브라우저별 통계",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Browser stats" }
        }
      }
    },
    "/analytics/recent": {
      "get": {
        "tags": ["Analytics"],
        "summary": "최근 페이지뷰",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Recent page views" }
        }
      }
    }
  }
}
